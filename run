#!/usr/bin/env bash
# ── ./run ────────────────────────────────────────────────────────────────────
# Start the Minecraft server if it's down. No-op if it's already running.
# This is the plain "bring the world up" command — for mod changes use
# scripts/deploy.sh instead.
#
# Usage:
#   ./run            # start the server if down; report status either way
#   ./run --logs     # ... then tail the logs (Ctrl-C to stop following)
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVER_DIR="$REPO_ROOT/apps/server"
SERVICE="minecraft"

FOLLOW=0
[ "${1:-}" = "--logs" ] || [ "${1:-}" = "-f" ] && FOLLOW=1

cd "$SERVER_DIR"

cid="$(docker compose ps -q "$SERVICE" 2>/dev/null || true)"
if [ -n "$cid" ] && [ "$(docker inspect -f '{{.State.Running}}' "$cid" 2>/dev/null)" = "true" ]; then
  echo "✓ server already up (container $(docker inspect -f '{{.Name}}' "$cid" | sed 's#^/##'))"
else
  echo "→ server is down — starting…"
  docker compose up -d
  echo "✓ started. First boot after a mod change re-downloads mods; give it a few minutes."
  echo "  Watch for \"Done (…)! For help, type help\" in the logs."
fi

if [ "$FOLLOW" = "1" ]; then
  echo "── tailing logs (Ctrl-C to stop) ──"
  exec docker compose logs -f "$SERVICE"
fi
