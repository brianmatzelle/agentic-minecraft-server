# Hermes secrets/Discord block  →  append to ~/.hermes/.env  (NEVER commit the real file)
# Key NAMES are [VERIFIED] as read by Hermes; values are placeholders.
#
# SECURITY: this token lives with HERMES/the bot host — NOT inside the OpenShell
# agent sandbox. Use a FRESHLY ROTATED token (the one shared in chat is burned).
DISCORD_BOT_TOKEN=REPLACE_ME_WITH_A_FRESHLY_ROTATED_TOKEN

# Authorization gate (deny-by-default). Comma-separated Discord IDs.
# CONFIRM these are honored by your installed Hermes adapter — they are the authz gate.
DISCORD_ALLOWED_USERS=
DISCORD_ALLOWED_ROLES=

# Where cron/proactive output is delivered:
DISCORD_HOME_CHANNEL=
DISCORD_REQUIRE_MENTION=true
DISCORD_REPLY_TO_MODE=first          # off | first | all

# The agent's brain (also injected into the sandbox as env):
ANTHROPIC_API_KEY=
