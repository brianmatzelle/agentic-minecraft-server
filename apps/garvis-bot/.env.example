# @Garvis bot env  →  copy to bot/.env  (gitignored). Use a FRESHLY ROTATED token.
DISCORD_BOT_TOKEN=REPLACE_ME_WITH_A_FRESHLY_ROTATED_TOKEN
DISCORD_APP_ID=                 # Application ID (Discord Developer Portal -> General Information)
DISCORD_GUILD_ID=              # the "PC" server's ID (right-click server -> Copy Server ID)

# Conversation log (Postgres) — durable transcript of every `!g` turn (player message,
# intent, Garvis's reply, claude session id, success, latency, cost). Points at the
# `postgres` sidecar in apps/server/docker-compose.yml (bound to 127.0.0.1:5432); the
# user/password/db MUST match POSTGRES_* in apps/server/.env. UNSET = logging is a
# silent no-op and the bot runs exactly as before (it's purely additive — see convlog.js).
GARVIS_PG_URL=                     # e.g. postgres://garvis:CHANGE_ME@127.0.0.1:5432/garvis  (blank = logging off)
# GARVIS_PG_POOL_MAX=4             # optional: max pooled connections (default 4)

# Behavior
GARVIS_COOLDOWN_MS=60000           # per-user cooldown for the expensive claude-spawning @mention actions (Q&A + mod requests)
GARVIS_WHITELIST_COOLDOWN_MS=1000  # per-user cooldown for /whitelist (cheap: docker + .env) — kept short

# Live moderation — natural-language server-mod actions (see src/moderation.js, docs/security.md).
# When ON, an @mention is first checked for a live moderator ACTION from the fixed verb
# catalog (ban/kick/op/whitelist/tp/give/gamerule/time/weather/restart/…). Garvis only
# ever picks a verb + args; the bot validates them and runs a fixed `docker exec rcon-cli`
# — the model never holds a shell, so there is no path to arbitrary host code execution.
GARVIS_MODERATION=on               # on | off  (kill switch for the whole feature)
GARVIS_MOD_ACTION_COOLDOWN_MS=3000 # per-user cooldown for live actions — kept short so a mod can act in quick succession
# DESTRUCTIVE verbs (ban/pardon, op/deop, kick, whitelist_remove, gamemode, ban-ip, restart)
# require the mod role OR the owner. Additive/reversible verbs (whitelist_add, tp, give,
# time, weather, broadcast, difficulty, gamerule, list) are open to everyone.
GARVIS_MOD_ROLE_ID=                # Discord role id whose members can run destructive verbs (blank => owner-only)
GARVIS_OWNER_ID=                   # your Discord user id — always allowed to run any verb

# In-game chat bridge — talk to Garvis IN MINECRAFT by typing `!g <message>` in chat
# (see src/ingame.js, docs/in-game-garvis.md). The bot tails `docker logs <MC_CONTAINER>`,
# runs the SAME read-only Q&A brain used for Discord @mentions, and replies in-game via
# `rcon-cli tellraw`. Q&A questions stay read-only; a MOD REQUEST ("!g add cobblemon")
# is routed to the SAME maintenance agent the Discord @mention path uses (it researches
# the mod + opens a PR — a human still merges). A real `/g` slash command (custom
# NeoForge mod) is the documented Phase 2.
GARVIS_INGAME=on                   # on | off  (kill switch for the whole !g bridge)
GARVIS_INGAME_TRIGGER=!g           # chat prefix that summons Garvis (whole leading token)
GARVIS_INGAME_REPLY_TARGET=@a      # who sees replies: @a (everyone) or a player selector; "thinking" acks always go to the asker
GARVIS_INGAME_COOLDOWN_MS=15000    # per-player cooldown (each !g spawns a claude turn — bounds spam + cost)
GARVIS_INGAME_MODREQ=on            # on | off  — allow !g mod requests (PRs); only acts when GARVIS_DISPATCH_MODE != dry-run. off = !g stays Q&A-only
GARVIS_INGAME_MAINT_COOLDOWN_MS=180000  # heavier per-player cooldown for !g mod requests (a full research+PR run, not a cheap Q&A turn)
# In-game GIVE — let players ask Garvis to give items in chat ("!g give me 64 stone",
# "!g give Steve an elytra"). Same validated catalog verb as the Discord `give`, run as a
# live `rcon-cli` (independent of GARVIS_DISPATCH_MODE). GATED on the in-game authority
# Discord's role can't see: the REQUESTER must be a SERVER OP (server-data/ops.json).
# Off by default — it hands out items. Non-ops are told to ask an op or use Discord.
GARVIS_INGAME_GIVE=off             # on | off  — allow !g give (op-gated). off = give requests fall back to Q&A
MC_OPS_FILE=                       # path to the live ops.json (blank = auto: ../../apps/server/server-data/ops.json)

# /whitelist — lets anyone whitelist Minecraft (Java) usernames (self-service). The bot
# does `docker exec <MC_CONTAINER> rcon-cli whitelist add <name>` (instant) AND appends
# the name to MC_WHITELIST in the server .env (survives restarts). Both default to the
# repo's docker-compose layout; override only for a non-default setup. The bot's host
# user must be able to run `docker` (the systemd unit's PATH already includes /usr/bin).
MC_CONTAINER=mc-neoforge        # name of the running itzg/minecraft-server container
MC_SERVER_ENV=                  # path to apps/server/.env (blank = auto: ../../apps/server/.env)
GARVIS_DISPATCH_MODE=dry-run    # dry-run | local | openshell
#   dry-run  — Garvis only ECHOES the task he would run (safe demo; @mentions stay help-only)
#   local    — Garvis runs a real claude agent that researches the mod + opens a PR
#   openshell— same, but the agent runs inside the OpenShell egress sandbox (see infra/openshell)
# When NOT dry-run, ANYONE can just say "@garvis add cobblemon" in plain English and
# Garvis will research it and open a PR (a human still merges). No allowlist; the
# per-user cooldown above is the only anti-spam gate. In dry-run @mentions stay Q&A-only.

# Isolated, writable repo clone the maintenance agent works in (NEVER the live repo,
# so its git branches/commits can't collide with anyone editing the real checkout).
# Defaults to a sibling "minecraft-agent" dir next to the repo if unset.
GARVIS_AGENT_WORKDIR=

# Ground-truth server facts Garvis uses in install-help answers. Keep in sync with
# the live server (the deploy step / modlist). SERVER_MODS = what players install
# CLIENT-side — now a one-click modpack, NOT a hand-picked jar list. Regenerate the
# pack (scripts/build-client-mrpack.mjs) whenever the modlist changes, then update
# this line + the raw link below. Server-only perf mods don't belong here.
SERVER_ADDRESS=host-ip:25565
SERVER_MODS=Don't hand-pick mods — import our one-click modpack (NeoForge 1.21.1, ~21 client mods pinned to the server's exact versions): download https://github.com/brianmatzelle/agentic-minecraft-server/raw/main/apps/client/starting-cc-client.mrpack then in Prism Launcher do Add Instance -> Import (or drag it into the Modrinth App). It includes Cobblemon + add-ons (Radical Trainers, Mega Showdown, SimpleTMs, CobbleDollars, Cobblepedia), Waystones, Sophisticated Backpacks, Farmer's Delight, CC: Tweaked, and optional Create/JEI/Jade. Full guide: docs/windows-client-install.md. Server-only perf mods (Lithium, FerriteCore, ModernFix, spark, Chunky, Noisium) are NOT needed on the client.

# Only used when GARVIS_DISPATCH_MODE=openshell: which egress sandbox to exec the
# maintenance agent in, and where the repo is checked out inside it. Bring the
# sandbox up first with infra/openshell/run.sh.
OPENSHELL_SANDBOX=mc-maint-agent
OPENSHELL_WORKDIR=/sandbox/minecraft
