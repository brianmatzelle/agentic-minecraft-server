# @Garvis bot env  →  copy to bot/.env  (gitignored). Use a FRESHLY ROTATED token.
DISCORD_BOT_TOKEN=REPLACE_ME_WITH_A_FRESHLY_ROTATED_TOKEN
DISCORD_APP_ID=                 # Application ID (Discord Developer Portal -> General Information)
DISCORD_GUILD_ID=              # the "PC" server's ID (right-click server -> Copy Server ID)

# Deny-by-default authz — comma-separated Discord IDs. Empty = nobody authorized.
DISCORD_ALLOWED_USERS=
DISCORD_ALLOWED_ROLES=

# Behavior
GARVIS_COOLDOWN_MS=60000        # per-user cooldown between /requestmod & @mention actions
GARVIS_DISPATCH_MODE=dry-run    # dry-run | local | openshell
#   dry-run  — Garvis only ECHOES the task he would run (safe demo; @mentions stay help-only)
#   local    — Garvis runs a real claude agent that researches the mod + opens a PR
#   openshell— same, but the agent runs inside the OpenShell egress sandbox (see infra/openshell)
# When NOT dry-run, an AUTHORIZED member can just say "@garvis add cobblemon" in plain
# English and Garvis will research it and open a PR. Q&A/help stays open to everyone.

# Isolated, writable repo clone the maintenance agent works in (NEVER the live repo,
# so its git branches/commits can't collide with anyone editing the real checkout).
# Defaults to a sibling "minecraft-agent" dir next to the repo if unset.
GARVIS_AGENT_WORKDIR=
