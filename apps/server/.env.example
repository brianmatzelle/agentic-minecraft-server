# ============================================================================
#  Copy this file to `.env` and fill in real values. `.env` is gitignored.
#  NEVER commit real secrets. The Discord token below is a placeholder.
# ============================================================================

# --- Minecraft server (Layer 1) ---------------------------------------------
MC_VERSION=1.21.1               # NeoForge target MC version (pinned, not "latest")
MC_MEMORY=6G                    # JVM heap for the modded server
LEVEL_SEED=                     # <<< YOUR CUSTOM WORLD SEED (blank = random) >>>
MC_MOTD=A NeoForge server, maintained by Garvis
MC_DIFFICULTY=normal
MC_MAX_PLAYERS=20
MC_WHITELIST=                   # comma-separated usernames allowed to join (blank = whitelist off, anyone can join)
MC_ENABLE_COMMAND_BLOCK=true    # allow command blocks (ops only can place/edit them); false to disable

# Mods auto-installed from Modrinth at container startup (comma-separated slugs).
# Verified server-safe on NeoForge 1.21.1 (performance/utility):
#   lithium (tick perf), ferrite-core (memory), modernfix (startup), spark (profiler), chunky (pregen)
# NOT sodium (client-only) or krypton (Fabric-only).
#   MODRINTH_PROJECTS=lithium,ferrite-core,modernfix,spark,chunky
MODRINTH_PROJECTS=

# Optional CurseForge modpack instead of/alongside Modrinth (needs an API key):
# CF_API_KEY=

# --- World backups (local, via the itzg/mc-backup sidecar) ------------------
# A second container snapshots ./server-data into ./backups on a schedule, using
# RCON to flush + pause world saves so each archive is consistent. See docs/backups.md.
RCON_PASSWORD=minecraft         # shared by the server + backup sidecar. Set a strong value (RCON port 25575 is internal-only, never exposed)
BACKUP_INTERVAL=24h             # how often to snapshot (e.g. 24h, 12h, 2h)
BACKUP_PRUNE_DAYS=7             # delete local archives older than this many days
TZ=UTC                          # timezone used in backup-filename timestamps

# --- Garvis Discord bot (Layer 3) -------------------------------------------
# Get a NEW token from Discord Developer Portal -> Bot -> Reset Token.
# The token you shared in chat is COMPROMISED — rotate it before using this.
DISCORD_BOT_TOKEN=REPLACE_ME_WITH_A_FRESHLY_ROTATED_TOKEN
DISCORD_GUILD_ID=               # the "PC" server's ID
DISCORD_MOD_REQUEST_CHANNEL_ID= # channel where friends @Garvis
# Allowlist who may drive the agent (comma-separated Discord user IDs / role IDs):
DISCORD_ALLOWED_USERS=
DISCORD_ALLOWED_ROLES=

# --- Maintenance agent (Layer 2: Hermes + Claude Code) ----------------------
ANTHROPIC_API_KEY=              # for the claude-code skill / Claude Agent SDK
ANTHROPIC_MAX_SPEND_USD=        # optional spend cap (kill-switch budget)
